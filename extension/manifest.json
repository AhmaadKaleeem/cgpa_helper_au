{
  "manifest_version": 3,
  "name": "AU GradePilot",
  "version": "1.0.0",
  "description": "GradePilot is a Chrome extension that calculates your exact AU CGPA and lets you simulate retakes and plan semesters privately.",
  "permissions": ["storage"],
  "host_permissions": ["https://portals.au.edu.pk/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://portals.au.edu.pk/*"],
      "js": [
        "src/env.js",
        "src/analytics.js",
        "src/constants.js",
        "src/types.js",
        "src/helpers.js",
        "src/eventBus.js",
        "src/storage.js",
        "src/validation.js",
        "src/engine.js",
        "src/optimizer.js",
        "src/parser.js",
        "src/notifications.js",
        "src/xlsx.full.min.js",
        "src/ui.js",
        "src/overlay.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/styles.css", "icons/*"],
      "matches": ["https://portals.au.edu.pk/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
