<UserControl x:Class="GradePilotInstaller.Views.ChromeSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

        <TextBlock Text="Load Extension in Chrome" Style="{StaticResource TypographyH1}" />
        <TextBlock Grid.Row="1" Text="Follow these steps to load GradePilot into Chrome." Style="{StaticResource TypographySubheading}" />

        <Border Grid.Row="2" Background="{DynamicResource BrushSurface}" CornerRadius="4" Padding="24">
            <StackPanel>
                <TextBlock Style="{StaticResource TypographyBody}" Margin="0,0,0,16" TextWrapping="Wrap">
                    Chrome did not open automatically, or it asked you to pick a profile. Open Chrome and type <Run FontWeight="SemiBold">chrome://extensions</Run> in the address bar.
                </TextBlock>
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Style="{StaticResource TypographyBody}" Margin="0,0,0,12">
                        <Run FontWeight="SemiBold">1.</Run> Turn on <Run FontWeight="SemiBold">Developer Mode</Run> (top right corner of Chrome).
                    </TextBlock>
                    <TextBlock Style="{StaticResource TypographyBody}" Margin="0,0,0,12">
                        <Run FontWeight="SemiBold">2.</Run> Click <Run FontWeight="SemiBold">Load unpacked</Run>.
                    </TextBlock>
                    <TextBlock Style="{StaticResource TypographyBody}">
                        <Run FontWeight="SemiBold">3.</Run> Select <Run FontWeight="SemiBold">this exact folder</Run> (select the folder itself, not a file inside it):
                    </TextBlock>
                    <TextBlock Style="{StaticResource TypographyCaption}" Foreground="{DynamicResource BrushPrimaryAction}" Margin="16,4,0,0" Text="{Binding InstallPath}" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Open Folder" Command="{Binding OpenFolderCommand}" Style="{StaticResource StyleSecondaryButton}" Margin="0,0,12,0" />
                    <Button Content="Copy Path" Command="{Binding CopyPathCommand}" Style="{StaticResource StyleSecondaryButton}" Margin="0,0,12,0" />
                    <Button Content="Open Chrome" Command="{Binding OpenChromeCommand}" Style="{StaticResource StyleSecondaryButton}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3" Style="{StaticResource TypographyBody}" Margin="0,16,0,0" TextWrapping="Wrap">
            Need help? See the <Hyperlink NavigateUri="https://github.com/AhmaadKaleeem/cgpa_helper_au/blob/main/extension/USER_MANUAL.md" RequestNavigate="Hyperlink_RequestNavigate">user manual</Hyperlink> for step-by-step instructions for every installation method.
        </TextBlock>
    </Grid>
    </ScrollViewer>
</UserControl>
