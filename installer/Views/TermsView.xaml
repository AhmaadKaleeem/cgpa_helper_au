<UserControl x:Class="GradePilotInstaller.Views.TermsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Terms of Service" Style="{StaticResource TypographyH1}" />

        <Border Grid.Row="1" Background="{DynamicResource BrushWhite}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,24">
            <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding TermsText}" Style="{StaticResource TypographyBody}" TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>

        <CheckBox Grid.Row="2" Content="I accept the Terms of Service" IsChecked="{Binding AcceptedTerms}" Margin="0,8,0,0" />
    </Grid>
</UserControl>
