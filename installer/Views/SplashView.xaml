<UserControl x:Class="GradePilotInstaller.Views.SplashView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image Source="/Assets/logo.png" Width="80" Height="80" Margin="0,0,0,24" />
            <TextBlock Text="GradePilot" Style="{StaticResource TypographyH1}" HorizontalAlignment="Center" Margin="0,0,0,8" />
            <TextBlock Text="Version 1.0.0" Style="{StaticResource TypographyCaption}" HorizontalAlignment="Center" Margin="0,0,0,48" />
            
            <TextBlock Text="Preparing Installer" Style="{StaticResource TypographyBody}" HorizontalAlignment="Center" Margin="0,0,0,8" />
            <ProgressBar IsIndeterminate="True" Width="200" />
        </StackPanel>
    </Grid>
</UserControl>
