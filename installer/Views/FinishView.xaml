<UserControl x:Class="GradePilotInstaller.Views.FinishView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="40">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- IconCheck path geometry -->
            <Path Width="48" Height="48" 
                  Data="{StaticResource IconCheck}" 
                  Stroke="{DynamicResource BrushPrimaryAction}" 
                  StrokeThickness="4" 
                  Stretch="Uniform" 
                  HorizontalAlignment="Center" 
                  Margin="0,0,0,24" />
                  
            <TextBlock Text="Installation Complete" Style="{StaticResource TypographyH1}" HorizontalAlignment="Center" Margin="0,0,0,16" />
            <TextBlock Text="GradePilot has been successfully configured. To get the most out of it:" Style="{StaticResource TypographySubheading}" HorizontalAlignment="Center" Margin="0,0,0,24" />
            
            <Border Background="{DynamicResource BrushSurface}" CornerRadius="4" Padding="24" Margin="0,0,0,32" HorizontalAlignment="Center" MinWidth="350">
                <StackPanel>
                    <TextBlock Style="{StaticResource TypographyBody}" Margin="0,0,0,12">
                        <Run FontWeight="SemiBold">• Pin GradePilot</Run> to your Chrome toolbar for easy access.
                    </TextBlock>
                    <TextBlock Style="{StaticResource TypographyBody}" Margin="0,0,0,12">
                        <Run FontWeight="SemiBold">• Open the Student Portal</Run> to let GradePilot analyze your transcript.
                    </TextBlock>
                    <TextBlock Style="{StaticResource TypographyBody}">
                        <Run FontWeight="SemiBold">• Enjoy</Run> automatic, private, and precise academic tracking!
                    </TextBlock>
                </StackPanel>
            </Border>
            
            <StackPanel Margin="0,0,0,32" HorizontalAlignment="Center">
                <CheckBox Content="Create Desktop Shortcut" IsChecked="{Binding CreateDesktopShortcut}" Margin="0,0,0,8" />
                <CheckBox Content="Create Start Menu Shortcut" IsChecked="{Binding CreateStartMenuShortcut}" />
            </StackPanel>
            
            <Button Content="Finish" Command="{Binding FinishCommand}" Style="{StaticResource StylePrimaryButton}" HorizontalAlignment="Center" MinWidth="120" />
        </StackPanel>
    </Grid>
</UserControl>
