<UserControl x:Class="GradePilotInstaller.Views.FinishView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Path Width="48" Height="48"
                      Data="{StaticResource IconCheck}"
                      Stroke="{DynamicResource BrushPrimaryAction}"
                      StrokeThickness="4"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,24" />

                <TextBlock Text="GradePilot is installed" Style="{StaticResource TypographyH1}" HorizontalAlignment="Center" Margin="0,0,0,16" />
                <TextBlock Text="The extension is ready. A few things to do next:" Style="{StaticResource TypographySubheading}" HorizontalAlignment="Center" Margin="0,0,0,24" />

                <Border Background="{DynamicResource BrushSurface}" CornerRadius="4" Padding="24" Margin="0,0,0,24" HorizontalAlignment="Center" MinWidth="380">
                    <StackPanel>
                        <TextBlock Style="{StaticResource TypographyBody}" Margin="0,0,0,12">
                            <Run FontWeight="SemiBold">1. Pin GradePilot</Run> to your Chrome toolbar for quick access.
                        </TextBlock>
                        <TextBlock Style="{StaticResource TypographyBody}" Margin="0,0,0,12">
                            <Run FontWeight="SemiBold">2. Open the Student Portal</Run> and go to your Grade Report.
                        </TextBlock>
                        <TextBlock Style="{StaticResource TypographyBody}">
                            <Run FontWeight="SemiBold">3. Your data stays in your browser.</Run> Nothing is sent to external servers.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Shortcuts -->
                <StackPanel Margin="0,0,0,24" HorizontalAlignment="Center">
                    <CheckBox Content="Create Desktop Shortcut" IsChecked="{Binding CreateDesktopShortcut}" Margin="0,0,0,8" />
                    <CheckBox Content="Create Start Menu Shortcut" IsChecked="{Binding CreateStartMenuShortcut}" />
                </StackPanel>

                <!-- Need Help section -->
                <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="4" Padding="20" Margin="0,0,0,28" HorizontalAlignment="Center" MinWidth="380">
                    <StackPanel>
                        <TextBlock Text="Need help?" Style="{StaticResource TypographyBody}" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="User Manual"
                                    Click="OpenUserManual_Click"
                                    Style="{StaticResource StyleSecondaryButton}"
                                    Margin="0,0,8,0" />
                            <Button Content="Contact Support"
                                    Click="ContactSupport_Click"
                                    Style="{StaticResource StyleSecondaryButton}"
                                    Margin="0,0,8,0" />
                            <Button Content="Report a Bug"
                                    Click="ReportBug_Click"
                                    Style="{StaticResource StyleSecondaryButton}" />
                        </StackPanel>
                        <TextBox Text="ahmadkaleeem1@gmail.com" Padding="0" IsReadOnly="True" BorderThickness="0" Background="Transparent" Style="{StaticResource TypographyCaption}" Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Button Content="Finish" Command="{Binding FinishCommand}" Style="{StaticResource StylePrimaryButton}" HorizontalAlignment="Center" MinWidth="120" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
