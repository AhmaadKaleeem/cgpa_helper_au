<UserControl x:Class="GradePilotInstaller.Views.FinishView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="48,32">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- IconCheck path geometry -->
            <Path Width="48" Height="48" 
                  Data="{StaticResource IconCheck}" 
                  Stroke="{DynamicResource BrushPrimaryAction}" 
                  StrokeThickness="4" 
                  Stretch="Uniform" 
                  HorizontalAlignment="Center" 
                  Margin="0,0,0,24" />
                  
            <TextBlock Text="Installation Complete" Style="{StaticResource TypographyH1}" HorizontalAlignment="Center" />
            <TextBlock Text="GradePilot is now ready to use on your computer." Style="{StaticResource TypographyBody}" HorizontalAlignment="Center" Margin="0,0,0,32" />
            
            <Button Content="Finish" Command="{Binding FinishCommand}" Style="{StaticResource StylePrimaryButton}" HorizontalAlignment="Center" MinWidth="120" />
        </StackPanel>
    </Grid>
</UserControl>
