<Window x:Class="GradePilotInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:GradePilotInstaller.Views"
        xmlns:viewmodels="clr-namespace:GradePilotInstaller.ViewModels"
        mc:Ignorable="d"
        Title="GradePilot Setup" 
        MinWidth="600" MinHeight="450" 
        Width="720" Height="600"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/logo.ico"
        Background="{DynamicResource BrushBackground}"
        FontFamily="{StaticResource FontFamilyPrimary}">
        
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <DataTemplate DataType="{x:Type viewmodels:SplashViewModel}">
            <views:SplashView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:WelcomeViewModel}">
            <views:WelcomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:TermsViewModel}">
            <views:TermsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:DirectoryViewModel}">
            <views:DirectoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:InstallingViewModel}">
            <views:InstallingView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ChromeSetupViewModel}">
            <views:ChromeSetupView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:FinishViewModel}">
            <views:FinishView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Main Content Area -->
        <ContentControl Grid.Row="0" Content="{Binding CurrentView}" Margin="0" />

        <!-- Footer Navigation Area -->
        <Border Grid.Row="1" 
                Background="{DynamicResource BrushSurface}" 
                BorderBrush="{DynamicResource BrushBorder}" 
                BorderThickness="0,1,0,0" 
                Padding="24,16"
                Visibility="{Binding IsFooterVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Button Content="_Cancel" 
                        AutomationProperties.Name="Cancel Installation"
                        Command="{Binding CancelCommand}" 
                        Style="{StaticResource StyleSecondaryButton}" 
                        HorizontalAlignment="Left"
                        IsCancel="True" />
                        
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="_Back" 
                            AutomationProperties.Name="Go Back"
                            Command="{Binding BackCommand}" 
                            Style="{StaticResource StyleSecondaryButton}" 
                            Margin="0,0,12,0" />
                    <Button Content="_Next" 
                            AutomationProperties.Name="Go to Next Step"
                            Command="{Binding NextCommand}" 
                            Style="{StaticResource StylePrimaryButton}" 
                            IsDefault="True" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
